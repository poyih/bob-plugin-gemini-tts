{
  "identifier": "bob-plugin-gemini-tts",
  "version": "1.2.2",
  "category": "tts",
  "name": "Gemini TTS",
  "summary": "使用 Google Gemini TTS API 进行语音合成。",
  "icon": "",
  "author": "poyih & Claude",
  "homepage": "https://github.com/poyih/bob-plugin-gemini-tts",
  "appcast": "https://github.com/poyih/bob-plugin-gemini-tts/raw/main/appcast.json",
  "minBobVersion": "1.20.0",
  "options": [
    {
      "identifier": "apiKey",
      "type": "text",
      "title": "API Key",
      "defaultValue": "",
      "textConfig": {
        "type": "secure",
        "placeholderText": "请输入 Gemini API Key"
      }
    },
    {
      "identifier": "apiUrl",
      "type": "text",
      "title": "自定义 API 地址",
      "defaultValue": "https://generativelanguage.googleapis.com",
      "desc": "仅限 HTTPS（本机地址可用 HTTP）；第三方代理会收到 API Key 和正文",
      "textConfig": {
        "type": "visible",
        "placeholderText": "https://generativelanguage.googleapis.com"
      }
    },
    {
      "identifier": "model",
      "type": "menu",
      "title": "模型",
      "defaultValue": "gemini-3.1-flash-tts-preview",
      "menuValues": [
        { "title": "Gemini 3.1 Flash TTS", "value": "gemini-3.1-flash-tts-preview" },
        { "title": "Gemini 2.5 Pro TTS", "value": "gemini-2.5-pro-preview-tts" },
        { "title": "Gemini 2.5 Flash TTS", "value": "gemini-2.5-flash-preview-tts" }
      ]
    },
    {
      "identifier": "voice",
      "type": "menu",
      "title": "声音",
      "defaultValue": "Kore",
