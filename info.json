    {
      "identifier": "instructions",
      "type": "text",
      "title": "语音指令",
      "defaultValue": "",
      "desc": "可选，用于控制语音风格和语气",
      "textConfig": {
        "type": "visible",
        "height": 80,
        "placeholderText": "如：用欢快的语气朗读、Say cheerfully"
      }
